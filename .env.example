# ─── EXPO Lead Capture — Environment Variables ───────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to Git

# ── MongoDB ─────────────────────────────────────────────────────
# Local:
MONGODB_URI=mongodb://127.0.0.1:27017/expo_leads

# MongoDB Atlas (cloud – recommended for production):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/expo_leads?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-string

# ── Server ──────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Your deployed app URL (used in password reset emails)
APP_URL=https://your-app.onrender.com

# CORS – restrict to your frontend domain in production
CORS_ORIGIN=*

# ── Email / SMTP (optional – for password reset emails) ──────────
# Gmail example (use App Password, not your real password):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=EXPO Leads <your.email@gmail.com>

